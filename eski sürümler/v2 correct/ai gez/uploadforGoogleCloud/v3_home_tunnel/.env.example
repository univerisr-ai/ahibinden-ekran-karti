# Telegram Ayarları
TELEGRAM_BOT_TOKEN_1=BURAYA_BOT_1_TOKENINIZI_YAPIŞTIRIN
TELEGRAM_BOT_TOKEN_2=BURAYA_BOT_2_TOKENINIZI_YAPIŞTIRIN
TELEGRAM_CHAT_ID=BURAYA_CHAT_ID_NIZI_YAPIŞTIRIN

# Sahibinden Ayarları
TARGET_URL=https://www.sahibinden.com/ekran-karti-masaustu

# WARP SOCKS5 Proxy (Nodriver fallback yöntemi için)
USE_WARP=true
WARP_SOCKS5=socks5://127.0.0.1:40000

# Genel Ayarlar
# Her yöntem için deneme sayısı
MAX_RETRIES=2
# Bot controller toplam timeout (birden fazla yöntem dener)
COOKIE_GEN_TIMEOUT=600
