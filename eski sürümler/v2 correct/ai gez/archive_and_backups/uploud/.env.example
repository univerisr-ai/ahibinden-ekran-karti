# Telegram bridge ayarlari (opsiyonel)
TELEGRAM_BOT_TOKEN=123456789:your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890

# GCS bridge ayarlari (onerilen cloud-to-cloud yontem)
# GCS_COOKIE_BUCKET=your-cookie-bucket
# GCS_COOKIE_OBJECT=cookie/latest.json
# GCS_COOKIE_HISTORY_PREFIX=cookie/history
# GOOGLE_APPLICATION_CREDENTIALS=/opt/ai-gez/service-account.json

# ==========================================
# RESIDENTIAL PROXY (Cloudflare Turnstile bypass icin ONERILEN)
# ==========================================
# Google Cloud / AWS / Azure gibi datacenter IP'leri Cloudflare tarafindan
# otomatik olarak yuksek riskli isaretlenir ve Turnstile CAPTCHA tetiklenir.
# Residential (ev tipi) proxy kullanmak bu sorunu cozer.
#
# Desteklenen formatlar:
#   HTTP:   http://kullanici:sifre@host:port
#   SOCKS5: socks5://kullanici:sifre@host:port
#
# Onerilen servisler (Turkiye residential IP destekleyen):
#   - Bright Data  : https://brightdata.com  (~$5/GB, en buyuk havuz)
#   - IPRoyal      : https://iproyal.com     (~$1.75/GB, en ucuz)
#   - Smartproxy   : https://smartproxy.com   (~$4/GB, kolay kurulum)
#
# Cookie alma islemi ~1-2MB veri tuketir, aylik maliyet ~$1'dan az.
# PROXY_URL=http://user:pass@proxy.example.com:22225

# ==========================================
# CLOUDFLARE BYPASS AYARLARI
# ==========================================
# uc_open_with_reconnect bekle suresi (saniye)
# Cloudflare challenge cozulene kadar CDP baglantisi kesilir.
# Daha yuksek deger = daha fazla sure verir ama daha yavas.
# RECONNECT_TIME_FIRST=8

# Maksimum cookie alma denemesi (headless -> headless2 -> GUI)
# MAX_COOKIE_ATTEMPTS=3

# Opsiyonel
# CHROME_VERSION_MAIN=145
# CHROME_PROFILE_DIR=/opt/ai-gez/.chrome_profile

# ==========================================
# SCRAPER PERFORMANS AYARLARI
# ==========================================
# SEGMENT_WORKERS=4
# PAGE_WORKERS=3
# PAGE_SIZE=50
# MAX_PAGES_PER_SEGMENT=20
# REQUEST_DELAY=0.6
# REQUEST_TIMEOUT=25
# MAX_RETRIES=3
